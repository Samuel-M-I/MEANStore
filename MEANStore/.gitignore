# === DEPENDENCIAS ===
# No subir node_modules (pesan demasiado y se regeneran con npm install)
node_modules/
Backend/node_modules/
Frontend/node_modules/
Frontend/frontend-app/node_modules/

# === VARIABLES DE ENTORNO (¡CRÍTICO PARA SEGURIDAD!) ===
# Contienen claves secretas, credenciales de BD, etc.
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env

# === ARCHIVOS DE CONFIGURACIÓN PERSONALES ===
# Configuraciones de tu editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# === LOGS (no son necesarios en el repo) ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# === BACKEND (Node.js/Express) ===
# Archivos generados
backend/coverage/
backend/dist/
backend/build/

# === FRONTEND (Angular) ===
# Carpetas generadas por Angular
frontend/frontend-app/dist/
frontend/frontend-app/tmp/
frontend/frontend-app/out-tsc/
